# =============================================================================
# Neuroforum environment variables — copy to `.env` and fill in the CHANGEME
# fields before `docker compose up`. `.env` is gitignored.
# =============================================================================

# --- Infra connection strings ---
# The docker-compose `backend` / `worker` / `mcp-server` services override these
# to in-network hostnames (postgres:5432 etc.), so these defaults matter mainly
# for host-side tools (uv run, alembic from shell, etc.).
DATABASE_URL=postgresql+asyncpg://forum:forum@postgres:5432/forum
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
# CHANGEME in any deployment you care about. Keep them in sync with the
# `minio` service env in docker-compose.yml.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGEME_minio_password_min_8_chars
MINIO_BUCKET=forum-media
MINIO_SECURE=false
# Public base URL where the browser can reach MinIO (for image src attrs).
# For local dev this is fine; for a public deploy replace with your host.
MINIO_PUBLIC_BASE_URL=http://localhost:9000

# --- Auth / crypto ---
# CHANGEME: generate a fresh random string of >=32 chars.
# Suggestion: `openssl rand -base64 48 | tr -d '=' | head -c 48`
SECRET_KEY=CHANGEME_replace_with_random_48_char_string_asap_pls
# CHANGEME: independent from SECRET_KEY. Encrypts BYO LLM API keys in DB.
# Rotating this without a migration invalidates all stored credentials.
ENCRYPTION_KEY=CHANGEME_independent_fernet_key_48_char_random_now

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Misc ---
ENVIRONMENT=development
# postgres | opensearch (opensearch is a stub that raises NotImplementedError)
SEARCH_BACKEND=postgres

# --- CORS (comma-separated extra origins on top of localhost:3000) ---
# Set this to your production frontend URL when deploying, e.g.
# CORS_ORIGINS=https://forum.example.com
CORS_ORIGINS=

# --- Frontend build arg (consumed by docker compose build --frontend) ---
# For a public deploy this needs to be the URL the *browser* uses to hit the
# API, not the internal docker hostname.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
